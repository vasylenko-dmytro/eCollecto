# eCollecto — environment variable template
# Copy this file to .env and adjust values if needed.
# Default values work for local development out of the box.

# ── MongoDB ──────────────────────────────────────────────
MONGO_INITDB_DATABASE=ecollecto
MONGO_PORT=27017

# ── Keycloak ─────────────────────────────────────────────
KC_VERSION=26.2
KC_PORT=8180
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin
KC_REALM=ecollecto

# ── Backend (Spring Boot) ────────────────────────────────
BACKEND_PORT=8080
SPRING_SECURITY_OAUTH2_ISSUER=http://localhost:8180/realms/ecollecto

# ── Frontend (Vite) ──────────────────────────────────────
# These are also declared in frontend/ecollecto-ui/.env.example
# Copy that file to frontend/ecollecto-ui/.env.local as well.
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=ecollecto
VITE_KEYCLOAK_CLIENT_ID=ecollecto-ui

